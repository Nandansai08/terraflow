# ==============================================================================
# TERRAFLOW LOCAL ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# This file serves as a template for local development environment variables.
# Copy this file to '.env' in the project root before running the application:
#   cp .env.example .env
#
# IMPORTANT: Use strong, high-entropy secrets in your local '.env' file.
# WARNING: NEVER commit the active '.env' file or any real production secrets
# to version control.
# ==============================================================================

# ==============================================================================
# REQUIRED LOCAL DEVELOPMENT VARIABLES
# ==============================================================================
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
DATABASE_URL="postgresql://terraflow_admin:terraflow_secure_pass_10M@localhost:5432/terraflow_db?schema=public"

# SECRETS WARNING: The authentication service verifies these variables on startup.
# Ensure they are set to strong, unique random keys (minimum 32 characters long).
JWT_SECRET=your_super_secret_jwt_access_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_minimum_32_characters_long

# ==============================================================================
# OPTIONAL CLIENT/SERVER URL VARIABLES (Defaults apply if omitted)
# ==============================================================================
# Web application API base URL (client-side)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Public API origin used for local upload URLs (server-side)
API_PUBLIC_URL=http://localhost:4000

# ==============================================================================
# OPTIONAL OAUTH VARIABLES
# ==============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=google-client-id-placeholder-obtain-from-console.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-placeholder-obtain-from-google-console
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Apple Sign-In (Disabled by default)
APPLE_CLIENT_ID=com.terraflow.auth.client
APPLE_TEAM_ID=ABC123XYZ9
APPLE_KEY_ID=1234567890
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/apple/callback

# ==============================================================================
# OPTIONAL STORAGE VARIABLES
# ==============================================================================
# Path to a Google Cloud service account JSON key file.
# FALLBACK: If left empty or referencing an invalid path, the StorageService
# automatically falls back to storing uploaded media files locally in the
# 'apps/api/public/uploads' directory.
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET_NAME=terraflow-memories-bucket

# ==============================================================================
# OPTIONAL WORKER VARIABLES (Required for worker queue/Redis features)
# ==============================================================================
REDIS_URL="redis://127.0.0.1:6379"
